---
// Location.astro — Two-column layout with salon address/hours info card on the left
// and an embedded Google Maps iframe on the right.
// No props needed; all data is hardcoded to the salon's real details.
---

<!-- Location section: white background, generous vertical padding -->
<section id="location" class="bg-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ── SECTION HEADING ────────────────────────────────────────────── -->
    <div class="reveal text-center mb-14">
      <!-- Decorative eyebrow label -->
      <p class="text-rosegold uppercase tracking-[0.25em] text-sm font-semibold mb-3">
        Come Visit Us
      </p>

      <!-- Main section title -->
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-gray-800">
        Find Us
      </h2>

      <!-- Underline accent -->
      <div class="w-16 h-1 bg-rosegold mx-auto mt-4 rounded-full"></div>
    </div>

    <!-- ── TWO-COLUMN LAYOUT ──────────────────────────────────────────── -->
    <!-- Stacks vertically on mobile, two equal columns on large screens -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-stretch">

      <!-- ── LEFT COLUMN: ADDRESS & HOURS CARD ──────────────────────── -->
      <div class="reveal reveal-delay-1 bg-rosegold-light rounded-3xl p-8 flex flex-col justify-between">

        <!-- ── ADDRESS BLOCK ──────────────────────────────────────────── -->
        <div class="mb-8">
          <!-- Row: pin icon + "Our Location" heading -->
          <div class="flex items-center mb-4">
            <!-- SVG map-pin icon (inline, no external icon library needed) -->
            <svg
              class="w-6 h-6 text-rosegold mr-3 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
            <h3 class="text-lg font-bold text-gray-800">Our Location</h3>
          </div>

          <!-- Full salon address — structured with address semantic element -->
          <address class="not-italic text-gray-600 leading-relaxed ml-9">
            4632 Forest Hill Blvd<br />
            West Palm Beach, FL 33415
          </address>

          <!-- Google Maps text link for easy navigation -->
          <a
            href="https://maps.google.com/?q=4632+Forest+Hill+Blvd,+West+Palm+Beach,+FL+33415"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-3 ml-9 text-rosegold hover:text-rosegold-dark text-sm font-medium underline underline-offset-2 transition-colors duration-200"
          >
            Get Directions &rarr;
          </a>
        </div>

        <!-- ── DIVIDER LINE ─────────────────────────────────────────── -->
        <div class="border-t border-rosegold/20 my-4"></div>

        <!-- ── HOURS BLOCK ─────────────────────────────────────────── -->
        <div>
          <!-- Row: clock icon + "Hours" heading -->
          <div class="flex items-center mb-4">
            <!-- SVG clock icon (inline, no external icon library needed) -->
            <svg
              class="w-6 h-6 text-rosegold mr-3 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <h3 class="text-lg font-bold text-gray-800">Hours</h3>
          </div>

          <!-- Hours table: day label on left, time on right -->
          <div class="ml-9 space-y-3">

            <!-- Monday – Saturday row -->
            <div class="flex justify-between items-center">
              <span class="text-gray-600 font-medium">Monday – Saturday</span>
              <!-- Green dot signals open -->
              <span class="flex items-center text-gray-800 font-semibold text-sm">
                <span class="w-2 h-2 rounded-full bg-green-400 mr-2" aria-hidden="true"></span>
                9:30 AM – 7:00 PM
              </span>
            </div>

            <!-- Thin separator between days -->
            <div class="border-t border-rosegold/10"></div>

            <!-- Sunday row -->
            <div class="flex justify-between items-center">
              <span class="text-gray-600 font-medium">Sunday</span>
              <!-- Red dot signals closed -->
              <span class="flex items-center text-gray-500 font-medium text-sm">
                <span class="w-2 h-2 rounded-full bg-red-400 mr-2" aria-hidden="true"></span>
                Closed
              </span>
            </div>

          </div><!-- end hours table -->
        </div><!-- end hours block -->

        <!-- ── PHONE / CONTACT PROMPT ───────────────────────────────── -->
        <div class="mt-8 bg-rosegold/10 rounded-2xl px-5 py-4">
          <p class="text-sm text-gray-600 text-center">
            Walk-ins welcome — appointments preferred.
          </p>
        </div>

      </div><!-- end left column -->

      <!-- ── RIGHT COLUMN: GOOGLE MAP IFRAME ────────────────────────── -->
      <!-- rounded-3xl and overflow-hidden clip the map to rounded corners -->
      <div class="reveal reveal-delay-2 rounded-3xl overflow-hidden shadow-lg h-[400px] lg:h-auto min-h-[400px]">
        <!-- Google Maps embed for the exact salon address -->
        <!-- title attribute required for accessibility (iframe must have a title) -->
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3565.340050860361!2d-80.11326442461327!3d26.637583670987445!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88d9298bcfffffff%3A0xe9c15865230fe41!2s4632%20Forest%20Hill%20Blvd%2C%20West%20Palm%20Beach%2C%20FL%2033415!5e0!3m2!1sen!2sus!4v1701234567890!5m2!1sen!2sus"
          width="100%"
          height="100%"
          style="border:0; display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Map showing Blessful Beauty Salon location at 4632 Forest Hill Blvd, West Palm Beach, FL"
        ></iframe>
      </div><!-- end right column (map) -->

    </div><!-- end two-column grid -->
  </div><!-- end container -->
</section>
